generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

enum FuelType {
  gasoline
  diesel
  hybrid
  electric
  lpg
  other
}

enum TransmissionType {
  manual
  automatic
  cvt
  other
}

enum MaintenanceCategory {
  oil_change
  filters
  tires
  battery
  brakes
  timing_belt
  air_conditioning
  insurance
  technical_inspection
  repair
  custom
}

enum ReminderStatus {
  planned
  sent
  done
  dismissed
}

enum NotificationChannel {
  push
  email
  in_app
}

enum NotificationStatus {
  unread
  read
  sent
  failed
}

enum FileType {
  invoice
  image
  registration
  insurance
  other
}

model User {
  id                        String              @id @default(cuid())
  email                     String              @unique
  passwordHash              String?
  firstName                 String?
  lastName                  String?
  avatarUrl                 String?
  locale                    String              @default("fr")
  role                      Role                @default(USER)
  emailVerifiedAt           DateTime?
  notificationPreferences   Json                @default("{\"push\":true,\"email\":true,\"inApp\":true}")
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  vehicles                  Vehicle[]
  refreshTokens             RefreshToken[]
  notifications             Notification[]
  aiRequests                AiRequest[]

  @@index([role])
  @@index([createdAt])
  @@map("users")
}

model RefreshToken {
  id           String   @id @default(cuid())
  tokenHash    String   @unique
  userId       String
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Vehicle {
  id              String               @id @default(cuid())
  userId          String
  brand           String
  model           String
  year            Int
  licensePlate    String?
  vin             String?
  currentMileage  Int
  fuelType        FuelType
  transmission    TransmissionType
  photoUrl        String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  mileageLogs     MileageLog[]
  records         MaintenanceRecord[]
  reminders       Reminder[]
  expenses        Expense[]
  files           UploadedFile[]

  @@unique([userId, licensePlate])
  @@index([userId])
  @@index([vin])
  @@map("vehicles")
}

model MileageLog {
  id         String   @id @default(cuid())
  vehicleId String
  mileage   Int
  notedAt   DateTime @default(now())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, notedAt])
  @@map("mileage_logs")
}

model MaintenanceRecord {
  id             String              @id @default(cuid())
  userId         String
  vehicleId      String
  category       MaintenanceCategory
  customCategory String?
  performedAt    DateTime
  mileage        Int
  cost           Decimal             @default(0) @db.Decimal(12, 2)
  garageName     String?
  notes          String?
  partsReplaced  String[]            @default([])
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  vehicle        Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  expenses       Expense[]
  files          UploadedFile[]
  reminders      Reminder[]

  @@index([userId, performedAt])
  @@index([vehicleId, category])
  @@map("maintenance_records")
}

model Reminder {
  id                  String               @id @default(cuid())
  userId              String
  vehicleId           String
  maintenanceRecordId String?
  category            MaintenanceCategory
  title               String
  dueDate             DateTime?
  dueMileage          Int?
  status              ReminderStatus       @default(planned)
  channels            NotificationChannel[] @default([push, email, in_app])
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  vehicle             Vehicle              @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  maintenanceRecord   MaintenanceRecord?   @relation(fields: [maintenanceRecordId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([vehicleId, dueDate])
  @@index([vehicleId, dueMileage])
  @@map("reminders")
}

model Expense {
  id                  String             @id @default(cuid())
  userId              String
  vehicleId           String
  maintenanceRecordId String?
  label               String
  amount              Decimal            @db.Decimal(12, 2)
  currency            String             @default("EUR")
  spentAt             DateTime
  vehicle             Vehicle            @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  maintenanceRecord   MaintenanceRecord? @relation(fields: [maintenanceRecordId], references: [id], onDelete: SetNull)

  @@index([userId, spentAt])
  @@index([vehicleId])
  @@map("expenses")
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  title     String
  body      String
  channel   NotificationChannel
  status    NotificationStatus  @default(unread)
  metadata  Json                @default("{}")
  createdAt DateTime            @default(now())
  readAt    DateTime?
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([createdAt])
  @@map("notifications")
}

model UploadedFile {
  id                  String             @id @default(cuid())
  userId              String
  vehicleId           String?
  maintenanceRecordId String?
  type                FileType
  fileName            String
  mimeType            String
  size                Int
  storageKey          String
  publicUrl           String?
  createdAt           DateTime           @default(now())
  vehicle             Vehicle?           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  maintenanceRecord   MaintenanceRecord? @relation(fields: [maintenanceRecordId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([vehicleId])
  @@map("uploaded_files")
}

model Garage {
  id          String   @id @default(cuid())
  name        String
  address     String?
  city        String?
  country     String?
  latitude    Decimal? @db.Decimal(9, 6)
  longitude   Decimal? @db.Decimal(9, 6)
  rating      Decimal? @db.Decimal(3, 2)
  phone       String?
  website     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([city, country])
  @@map("garages")
}

model AiRequest {
  id        String   @id @default(cuid())
  userId    String
  vehicleId String?
  prompt    String
  response  Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("ai_requests")
}
